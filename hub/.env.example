# Store Hub secrets — copy to .env and fill in. Runbook: docs/ops/store-hub-setup.md
# Postgres password for the hub's local database (any strong random string).
HUB_DB_PASSWORD=
# JWT signing secret for sessions minted BY THE HUB (independent of the cloud's).
HUB_JWT_SECRET=
# Field-encryption key for the hub DB (independent of the cloud's).
HUB_APP_ENC_KEY=
# MUST equal the cloud's HUB_SYNC_SECRET — verifies the snapshot signature at import.
HUB_SYNC_SECRET=
# The public origin devices use for this store (per-store DNS name), e.g. https://store1.pos.example.com
HUB_ORIGIN=
# Optional: creates/rotates a local `hubadmin` (Admin) at import so the box is administrable offline.
HUB_ADMIN_PASSWORD=
# The cloud API origin for the hub-push replay (Phase 2a), e.g. https://erp.example.com
CLOUD_URL=
# Stable identifier for THIS box in the fleet view (defaults to the container hostname).
HUB_ID=

{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm install && pnpm --filter @ierp/shared build && pnpm --filter @ierp/api build"
  },
  "deploy": {
    "startCommand": "node apps/api/dist/main.js",
    "preDeployCommand": "pnpm --filter @ierp/api db:migrate",
    "healthcheckPath": "/",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}

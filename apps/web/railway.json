{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm install && pnpm --filter @ierp/shared build && pnpm --filter @ierp/web build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @ierp/web start",
    "healthcheckPath": "/login",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}

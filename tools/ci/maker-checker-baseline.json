{
  "_note": "SOX-ICFR #6 maker-checker coverage gate (tools/ci/check-maker-checker.mjs). `exempt` lists state-mutating approve/override/authorize/certify/reverse/release routes whose OWNING module has no inline assertMakerChecker/assertActionAllowed, yet are covered another way (cross-module delegation) or are genuinely not a self-approval surface. Every entry needs a `reason`; a NEW sensitive route in a non-enforcing module that is not exempted FAILS the build. `inventory` is auto-written by --update and is informational only. The list may grow with justification (use-client precedent) and stale entries are rejected.",
  "exempt": {
    "POST /api/payroll/runs/:period/approve": {
      "reason": "Maker-checker enforced cross-module via the ledger: PayrollService.approvePayroll delegates to LedgerService.approveEntry (GL-05), which asserts approver != preparer on the Draft JE. Payroll is a top fraud-risk cycle and cannot be self-posted."
    },
    "POST /api/planning/versions/:id/approve": {
      "reason": "Budget-version approval gates on the workflow engine (WorkflowService.assertCanTransition('BUDGET')), which carries the MAKER_CHECKER SoD rule kind. Approves a plan version, not a GL posting."
    },
    "POST /api/retention/:id/release": {
      "reason": "The GL effect is a Draft JE posted via LedgerService.postEntry (GL-05) that a different user must approve before it is effective; the release call only stages it. Route is gl_close/exec gated."
    },
    "POST /api/pos/override": {
      "reason": "Manager authorization of a cashier's exception (price/discount/void), a different-role, permission-gated control by design (a supervisor overrides a cashier) — not self-approval of the actor's own document."
    },
    "POST /api/loyalty/clock-in/override": {
      "reason": "Attendance/labor time-clock correction (an override of a clock-in), permission-gated and audited; there is no financial document with a maker to self-approve."
    },
    "POST /api/lots/:lotNo/release": {
      "reason": "QC quality disposition — releasing a lot from a QC hold. Permission-gated; the QC inspector legitimately places and lifts holds, so there is no separate document-maker to conflict with (not a maker-checker surface)."
    }
  },

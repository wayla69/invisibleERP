# Tier 0 (Alibaba Cloud single-host) environment.
# Copy to .env on the ECS host and fill in REAL values. Never commit the real .env.
#   cp tools/ops/alibaba/.env.example tools/ops/alibaba/.env  &&  $EDITOR tools/ops/alibaba/.env

# ── public address ───────────────────────────────────────────────────────────
# Full public origin of the app. Baked into the web build AND used as the API CORS origin.
# Same-origin design: do NOT add a /api suffix and do NOT use a separate API host.
PUBLIC_SITE_URL=https://erp.example.co.th
# What Caddy serves on. A bare domain → automatic HTTPS. Use ":80" only for quick HTTP testing.
CADDY_SITE_ADDRESS=erp.example.co.th
#
# HTTP-ONLY TEST (no domain / no TLS) — set BOTH of the above to match the host you browse from, e.g.:
#   PUBLIC_SITE_URL=http://203.0.113.10     (your ECS public IP, or http://localhost on the box)
#   CADDY_SITE_ADDRESS=:80
# NEXT_PUBLIC_API_URL is baked at build time, so changing PUBLIC_SITE_URL needs `up -d --build`.

# ── database (Postgres runs in the db container) ──────────────────────────────
POSTGRES_USER=ierp
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=invisible_erp_v2
# Host-side localhost port the backup/restore-drill cron connects to (container is always 5432).
POSTGRES_HOST_PORT=5432

# ── app secrets (the API refuses to boot in production without these) ──────────
# Generate strong values, e.g.:  openssl rand -hex 32
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
APP_ENC_KEY=CHANGE_ME_openssl_rand_hex_32      # AES-256-GCM key for encrypted-at-rest fields (TOTP/webhook secrets)
PSP_WEBHOOK_SECRET=CHANGE_ME_psp_webhook_secret
# IMPORTANT: keep APP_ENC_KEY backed up separately + securely. Restoring the DB without the SAME
# APP_ENC_KEY makes encrypted fields undecryptable (see tools/ops/BACKUP-RUNBOOK.md).

# ── locale ────────────────────────────────────────────────────────────────────
BUSINESS_TZ_OFFSET_MIN=420   # Asia/Bangkok = UTC+7
TZ=Asia/Bangkok

# ── backups → Alibaba Cloud OSS ───────────────────────────────────────────────
# Local copies are kept under BACKUP_DIR; offsite copies pushed to OSS via a preconfigured
# rclone remote. Configure the remote once on the host:  rclone config
#   name=oss  type=s3  provider=Alibaba  access_key_id=…  secret_access_key=…
#   endpoint=oss-ap-southeast-7-internal.aliyuncs.com   (Bangkok, internal = free egress from ECS)
BACKUP_DIR=/var/backups/ierp
BACKUP_OSS=oss:ierp-backups/prod   # rclone remote:bucket/prefix  (empty ⇒ local-only, not recommended)
RETAIN_DAYS=14

# ── Tier 1 only (external ApsaraDB RDS) — leave commented while on Tier 0 ──────
# After running migrate-tier0-to-tier1.sh and cutting over to docker-compose.tier1.yml:
#   DATABASE_URL=postgresql://<rds-user>:<pw>@<rds-host>:5432/invisible_erp_v2  # api → RDS
#   BACKUP_DB_URL=postgresql://<rds-user>:<pw>@<rds-host>:5432/invisible_erp_v2 # backups dump RDS
#   DRILL_ADMIN_URL=postgresql://<rds-master>:<pw>@<rds-host>:5432/postgres     # restore-drill scratch on RDS

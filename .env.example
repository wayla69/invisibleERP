# ── Shared / API ──────────────────────────────────────────────
# PostgreSQL (Railway managed). Use the postgresql:// scheme (NOT postgres://).
DATABASE_URL=postgresql://user:pass@localhost:5432/invisible_erp_v2

# Auth — REQUIRED outside NODE_ENV=development (no insecure default unlike V1)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1h            # short-lived access token; the refresh flow (7d cookie) silently renews it
# AUTH_COOKIE_MAX_AGE=3600   # optional override; defaults to the JWT TTL (docs/24 R2-4)

# Encryption-at-rest for TOTP/MFA seeds + webhook secrets (AES-256-GCM).
# REQUIRED outside NODE_ENV=development|test. Rotating it invalidates stored secrets.
APP_ENC_KEY=change-me-to-a-long-random-string

# Business timezone for doc numbers / accounting dates (minutes offset; 420 = UTC+7 Asia/Bangkok)
BUSINESS_TZ_OFFSET_MIN=420

# ── Multi-tenancy & onboarding (ITGC-AC-18) — see docs/ops/tenancy-model.md ────
# TENANCY_MODE selects a per-tenant Admin's Row-Level-Security scope:
#   single-company (default) — every Admin gets a GLOBAL bypass and sees ALL tenants (correct for ONE
#                              company with many branches/outlets).
#   multi-company            — each Admin is confined to its own org (org_id); a fresh signup sees only
#                              its own company. REQUIRED on every API service sharing this DB if outsiders
#                              can sign up, or one Admin would see every company's data.
TENANCY_MODE=single-company
# STRICT_TENANCY_BOOT — make the 4.2 data-isolation boot check fail-closed. In production, if several
# companies (tenants) exist while TENANCY_MODE=single-company (where every tenant Admin has a GLOBAL RLS
# bypass), the API logs a loud error by default; set this to 1 to REFUSE to boot instead. Off by default so
# it can never brick an existing deploy on a heuristic. See docs/ops/tenancy-model.md.
STRICT_TENANCY_BOOT=0

# LEGACY_SHA256_LOGIN (4.5) — the pre-V2 unsalted-SHA-256 password path is a weak-hash acceptance path.
# On by default so an un-migrated account can log in once (it is then upgraded to scrypt). Set to `off`
# once every account has logged in at least once, to reject the weak comparison entirely. AuthService logs
# a warning naming any account that still uses it, so you can see when it is safe to disable.
LEGACY_SHA256_LOGIN=on

# ENFORCE_PRIVILEGED_MFA (4.4) — when on, a privileged role (Admin / finance / access-admin) that has NOT
# enrolled TOTP is HARD-BLOCKED (403 MFA_ENROLLMENT_REQUIRED) from every route except the MFA-setup /
# me / logout / change-password endpoints, until it enrols — the must_setup_mfa client nudge becomes a
# server gate. Off by default (grandfather) so existing un-enrolled privileged users aren't locked out;
# turn on after telling those users to enrol. See compliance/policies/07-access-control-policy.md.
ENFORCE_PRIVILEGED_MFA=false
# PLATFORM_ADMIN_USERNAMES — comma-separated usernames of the platform owner(s). Two powers:
#   1) provision/suspend companies via the @PlatformAdmin endpoints (POST /api/admin/tenants, …), and
#   2) "god": a GLOBAL RLS bypass on EVERY route — sees/operates across ALL tenants even under
#      multi-company, while ordinary Admins stay org-scoped. Env-gated (not an assignable role) so an
#      in-app Admin cannot escalate into it. Empty ⇒ nobody (secure default). Treat as break-glass:
#      few named humans, MFA on that Admin login, remove when no longer needed.
PLATFORM_ADMIN_USERNAMES=
# PUBLIC_SIGNUP_ENABLED — allow the PUBLIC self-serve POST /api/auth/signup (mints a tenant + an Admin).
# Fail-closed in production: unset/false ⇒ 403 SIGNUP_DISABLED (prefer the platform-admin/invite/approval
# flows). Only enable for open SaaS self-service — and ONLY together with TENANCY_MODE=multi-company.
PUBLIC_SIGNUP_ENABLED=false

# ── Plan entitlement gating (Wave 1 · 1.2) ─────────────────────────────────────────────────────────
# Suite-based plan gating (docs/36). DEFAULT-OFF so it never breaks an existing tenant. Roll out as:
#   1) leave both off → legacy behaviour (only @RequiresPlanFeature gates, e.g. ai_chat).
#   2) ENTITLEMENTS_SHADOW=true → dry-run: logs "[shadow] WOULD block …" without blocking. Watch the logs.
#   3) Backfill every tenant's plan row (features.suites) — 1.3 — THEN set ENTITLEMENTS_ENFORCE=true to gate
#      modules by plan (403 SUITE_NOT_ENTITLED). The per-tenant Admin bypass is removed; only the platform
#      owner (PLATFORM_ADMIN_USERNAMES) bypasses.
ENTITLEMENTS_ENFORCE=false
ENTITLEMENTS_SHADOW=false
# BILLING_GRACE_DAYS (1.4) — when ENTITLEMENTS_ENFORCE is on, a PastDue subscription keeps READ access for
# this many days after current_period_end (mutations blocked → 403 SUBSCRIPTION_PASTDUE_READONLY); after
# the window all access is blocked (SUBSCRIPTION_INACTIVE). Default 7. So a lapsed payer can always still
# see their data and fix billing during the grace period.
BILLING_GRACE_DAYS=7

# Observability / payments (all optional — unset = feature off)
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
# Card/PSP gateways for the tender path (gateway=opn|stripe). Unset → falls back to the mock gateway,
# so dev/test never charge. With a key set, a card tender carrying a token makes a REAL charge.
OPN_SECRET_KEY=
STRIPE_SECRET_KEY=
# PSP webhook (POST /api/payments/psp/webhook) signature secret. REQUIRED in production — the public
# webhook is rejected (401) without it. Set PSP_WEBHOOK_SECRET, or per-provider PSP_WEBHOOK_SECRET_<PROVIDER>
# (e.g. PSP_WEBHOOK_SECRET_OPN). Callers sign the raw body HMAC-SHA256 and send it as `x-psp-signature`.
PSP_WEBHOOK_SECRET=

# RD/ETDA e-Tax Invoice (all optional — unset = mock/sandbox + unsigned instance documents).
#   Signing: provide the CA-issued cert + key as PEM (newlines or \n), or the *_B64 base64 variants.
#   Submission: ETAX_PROVIDER=mock (default) | http. For http, set the SP endpoint + bearer token.
ETAX_PROVIDER=mock
ETAX_PROVIDER_URL=
ETAX_PROVIDER_TOKEN=
ETAX_PROVIDER_AUTH_HEADER=Authorization
ETAX_SIGNING_CERT_PEM=
ETAX_SIGNING_KEY_PEM=
# ETAX_SIGNING_CERT_PEM_B64=
# ETAX_SIGNING_KEY_PEM_B64=

# Delivery aggregators (Grab / LINE MAN / Foodpanda / Robinhood). Inbound webhook auth uses a per-platform
# shared secret (WEBHOOK_SECRET_<PLATFORM>, else CHANNEL_WEBHOOK_SECRET); the OUTBOUND adapter (menu push,
# order accept/reject/status callback) uses a real partner client when CHANNEL_API_URL_<PLATFORM> is set,
# else a mock. All optional — unset = mock, no real platform calls.
WEBHOOK_SECRET_GRAB=
CHANNEL_API_URL_GRAB=
CHANNEL_API_TOKEN_GRAB=
# …repeat per platform: WEBHOOK_SECRET_LINEMAN / CHANNEL_API_URL_LINEMAN / CHANNEL_API_TOKEN_LINEMAN, etc.

# LINE OA / member CRM (all optional — unset = dev mock, no real LINE calls).
#   LINE_CHANNEL_TOKEN     — Messaging API channel access token (push to members' LINE userIds)
#   LINE_LOGIN_CHANNEL_ID  — LINE Login/LIFF channel id (verifies member id tokens → LINE userId)
LINE_CHANNEL_TOKEN=
LINE_LOGIN_CHANNEL_ID=

# Wallet passes (docs/29 V5) — member card in Apple/Google Wallet. All optional: unset = deterministic
# mock provider (pass payload + fake install link, nothing leaves the building). Real signing creds are an
# ops prerequisite — set them and the same code issues real passes (per-tenant override via settings too).
WALLET_APPLE_CERT_P12=          # base64 pass-type signing cert (.p12)
WALLET_APPLE_CERT_PASSWORD=
WALLET_APPLE_WWDR=              # Apple WWDR intermediate cert (PEM)
WALLET_APPLE_TEAM_ID=
WALLET_APPLE_PASS_TYPE_ID=      # e.g. pass.co.th.oshinei.member
WALLET_GOOGLE_SA_EMAIL=         # Google Wallet API service account
WALLET_GOOGLE_SA_KEY=           # service-account private key (PEM, \n-escaped)
WALLET_GOOGLE_ISSUER_ID=

# Anthropic (AI assistant + analytics). Empty = analytics fall back to rule-based.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# RAG (Phase D2): embedding provider (default 'local' deterministic, offline) + retrieval threshold
EMBED_PROVIDER=local
KB_MIN_SCORE=0.15

# CORS — explicit origins (comma-separated). NOT "*".
CORS_ORIGINS=http://localhost:3000

# Server
PORT=8000
NODE_ENV=development

# ── Web ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
# LINE LIFF wrapper for /m (optional): the LIFF app id from LINE Developers Console. Set → opening /m
# inside LINE signs the member in with one tap (id_token → /api/member/auth/line; first time falls back
# to OTP and auto-links). Unset → the plain phone-OTP flow, no LIFF SDK loaded.
NEXT_PUBLIC_LIFF_ID=

# ── ETL (migration) ───────────────────────────────────────────
LEGACY_SQLITE_PATH=../Invisible ERP/Inventory_Master_DB.sqlite
LEGACY_MASTER_CSV=../Invisible ERP/Shared_Data/master_data.csv

# Multi-replica realtime fan-out (docs/24 R1-3): unset = in-memory SSE buses (single node / CI).
# Set to a Redis URL when running 2+ API replicas so live KDS/BI events reach every node.
# REALTIME_REDIS_URL=redis://localhost:6379

# Required by db:seed when creating the initial admin (docs/27 R0-3): the seed never generates or logs
# a credential; the account is must_change_password until rotated on first login.
# SEED_ADMIN_PASSWORD=change-me-on-first-login

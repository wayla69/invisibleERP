# ── Shared / API ──────────────────────────────────────────────
# PostgreSQL (Railway managed). Use the postgresql:// scheme (NOT postgres://).
DATABASE_URL=postgresql://user:pass@localhost:5432/invisible_erp_v2

# Auth — REQUIRED outside NODE_ENV=development (no insecure default unlike V1)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1h            # short-lived access token; the refresh flow (7d cookie) silently renews it
# AUTH_COOKIE_MAX_AGE=3600   # optional override; defaults to the JWT TTL (docs/24 R2-4)

# Encryption-at-rest for TOTP/MFA seeds + webhook/SSO/messaging secrets + PII columns (AES-256-GCM).
# REQUIRED outside NODE_ENV=development|test. Do NOT swap this value in place — rotate via the keyring:
# stage APP_ENC_KEYRING + APP_ENC_ACTIVE_KID, then run the key_rotation_sweep job (docs/ops/secrets.md §4).
APP_ENC_KEY=change-me-to-a-long-random-string
# Versioned keyring for key rotation (ITGC-AC-12 / 4.3). Unset = legacy single key (key id 1), inert.
# APP_ENC_KEYRING={"2":"another-long-random-string"}   # JSON kid→secret; HKDF-derived, label-separated
# APP_ENC_ACTIVE_KID=2                                 # new writes use this kid (v2:<kid>:… format)

# Business timezone for doc numbers / accounting dates (minutes offset; 420 = UTC+7 Asia/Bangkok)
BUSINESS_TZ_OFFSET_MIN=420

# ── Multi-tenancy & onboarding (ITGC-AC-18) — see docs/ops/tenancy-model.md ────
# TENANCY_MODE selects a per-tenant Admin's Row-Level-Security scope:
#   single-company (default) — every Admin gets a GLOBAL bypass and sees ALL tenants (correct for ONE
#                              company with many branches/outlets).
#   multi-company            — each Admin is confined to its own org (org_id); a fresh signup sees only
#                              its own company. REQUIRED on every API service sharing this DB if outsiders
#                              can sign up, or one Admin would see every company's data.
TENANCY_MODE=single-company
# DATA-ISOLATION BOOT CHECKS (security review H-3 / H-4) — both are FAIL-CLOSED by default in production
# (they refuse to boot on a dangerous state) and a no-op in dev/test. Each has an explicit opt-out that
# downgrades the refusal to a loud warning. (Replaces the old STRICT_TENANCY_BOOT flag, now removed — the
# fail-closed behaviour it enabled is the default.) See docs/ops/tenancy-model.md.
#
# H-4 — if several companies (tenants) exist while TENANCY_MODE=single-company (where every tenant Admin has
# a GLOBAL RLS bypass and can read ALL companies' data), the API REFUSES to boot. Fix by switching to
# TENANCY_MODE=multi-company (and backfilling org_id) or consolidating to one tenant. Set this to 1 only if
# you deliberately accept the cross-tenant visibility (NOT recommended):
# ALLOW_SINGLE_COMPANY_MULTI_TENANT=0
#
# H-3 — RLS is enforced only inside the per-request app_user transaction; @NoTx/SSE/raw/background-job paths
# run on the base connection. If that base DB role is a SUPERUSER or has BYPASSRLS (the managed-Postgres
# default), RLS is NOT enforced there and those paths have no DB-level tenant backstop, so the API REFUSES to
# boot. Fix by connecting as a dedicated NON-SUPERUSER, NON-BYPASSRLS owner role granted app_user (see
# docs/ops/tenancy-model.md). Set this to 1 to boot with a warning instead (NOT recommended in prod):
# ALLOW_RLS_BYPASS_BASE_ROLE=0

# (4.5) The pre-V2 unsalted-SHA-256 login path has been REMOVED entirely (weak-hash sink). A dormant
# un-migrated account can no longer authenticate on its legacy hash and must be reset by an admin
# (must_change_password). No env flag — there is nothing left to toggle.

# ENFORCE_PRIVILEGED_MFA (4.4) — when on, a privileged role (Admin / finance / access-admin) that has NOT
# enrolled TOTP is HARD-BLOCKED (403 MFA_ENROLLMENT_REQUIRED) from every route except the MFA-setup /
# me / logout / change-password endpoints, until it enrols — the must_setup_mfa client nudge becomes a
# server gate. Off by default (grandfather) so existing un-enrolled privileged users aren't locked out;
# turn on after telling those users to enrol. See compliance/policies/07-access-control-policy.md.
ENFORCE_PRIVILEGED_MFA=false
# PLATFORM_ADMIN_USERNAMES — comma-separated usernames of the platform owner(s). Two powers:
#   1) provision/suspend companies via the @PlatformAdmin endpoints (POST /api/admin/tenants, …), and
#   2) "god": a GLOBAL RLS bypass on EVERY route — sees/operates across ALL tenants even under
#      multi-company, while ordinary Admins stay org-scoped. Env-gated (not an assignable role) so an
#      in-app Admin cannot escalate into it. Empty ⇒ nobody (secure default). Treat as break-glass:
#      few named humans, MFA on that Admin login, remove when no longer needed.
PLATFORM_ADMIN_USERNAMES=
# PUBLIC_SIGNUP_ENABLED — allow the PUBLIC self-serve POST /api/auth/signup (mints a tenant + an Admin).
# Fail-closed in production: unset/false ⇒ 403 SIGNUP_DISABLED (prefer the platform-admin/invite/approval
# flows). Only enable for open SaaS self-service — and ONLY together with TENANCY_MODE=multi-company.
PUBLIC_SIGNUP_ENABLED=false

# ── Plan entitlement gating (Wave 1 · 1.2) ─────────────────────────────────────────────────────────
# Suite-based plan gating (docs/36). DEFAULT-OFF so it never breaks an existing tenant. Roll out as:
#   1) leave both off → legacy behaviour (only @RequiresPlanFeature gates, e.g. ai_chat).
#   2) ENTITLEMENTS_SHADOW=true → dry-run: logs "[shadow] WOULD block …" without blocking. Watch the logs.
#   3) Backfill every tenant's plan row (features.suites) — 1.3 — THEN set ENTITLEMENTS_ENFORCE=true to gate
#      modules by plan (403 SUITE_NOT_ENTITLED). The per-tenant Admin bypass is removed; only the platform
#      owner (PLATFORM_ADMIN_USERNAMES) bypasses.
ENTITLEMENTS_ENFORCE=false
ENTITLEMENTS_SHADOW=false
# BILLING_GRACE_DAYS (1.4) — when ENTITLEMENTS_ENFORCE is on, a PastDue subscription keeps READ access for
# this many days after current_period_end (mutations blocked → 403 SUBSCRIPTION_PASTDUE_READONLY); after
# the window all access is blocked (SUBSCRIPTION_INACTIVE). Default 7. So a lapsed payer can always still
# see their data and fix billing during the grace period.
BILLING_GRACE_DAYS=7

# Observability / payments (all optional — unset = feature off)
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
# Card/PSP gateways for the tender path (gateway=opn|stripe). Unset → falls back to the mock gateway,
# so dev/test never charge. With a key set, a card tender carrying a token makes a REAL charge.
OPN_SECRET_KEY=
STRIPE_SECRET_KEY=
# PSP webhook (POST /api/payments/psp/webhook) signature secret. REQUIRED in production — the public
# webhook is rejected (401) without it. Set PSP_WEBHOOK_SECRET, or per-provider PSP_WEBHOOK_SECRET_<PROVIDER>
# (e.g. PSP_WEBHOOK_SECRET_OPN). Callers sign the raw body HMAC-SHA256 and send it as `x-psp-signature`.
PSP_WEBHOOK_SECRET=
# Optional replay window (security review L-1). When a PSP also sends `x-psp-timestamp` (unix seconds), the
# signature must cover `"<timestamp>.<rawBody>"` and the timestamp must be within this many seconds of now —
# a captured callback replayed later goes stale and is refused (401 WEBHOOK_STALE). Default 300s. Senders
# that don't send a timestamp keep the body-only signature (back-compat).
PSP_WEBHOOK_TOLERANCE_SEC=300

# RD/ETDA e-Tax Invoice (all optional — unset = mock/sandbox + unsigned instance documents).
#   Signing: provide the CA-issued cert + key as PEM (newlines or \n), or the *_B64 base64 variants.
#   Submission: ETAX_PROVIDER=mock (default) | http. For http, set the SP endpoint + bearer token.
ETAX_PROVIDER=mock
ETAX_PROVIDER_URL=
ETAX_PROVIDER_TOKEN=
ETAX_PROVIDER_AUTH_HEADER=Authorization
ETAX_SIGNING_CERT_PEM=
ETAX_SIGNING_KEY_PEM=
# ETAX_SIGNING_CERT_PEM_B64=
# ETAX_SIGNING_KEY_PEM_B64=

# Delivery aggregators (Grab / LINE MAN / Foodpanda / Robinhood). Inbound webhook auth uses a per-platform
# shared secret (WEBHOOK_SECRET_<PLATFORM>, else CHANNEL_WEBHOOK_SECRET); the OUTBOUND adapter (menu push,
# order accept/reject/status callback) uses a real partner client when CHANNEL_API_URL_<PLATFORM> is set,
# else a mock. All optional — unset = mock, no real platform calls.
WEBHOOK_SECRET_GRAB=
CHANNEL_API_URL_GRAB=
CHANNEL_API_TOKEN_GRAB=
# …repeat per platform: WEBHOOK_SECRET_LINEMAN / CHANNEL_API_URL_LINEMAN / CHANNEL_API_TOKEN_LINEMAN, etc.
# Stronger inbound auth (security review L-2): set an HMAC signing secret and the platform must send an
# HMAC-SHA256 of the raw body in `x-webhook-signature` (optionally `x-webhook-timestamp` for a replay window)
# instead of echoing a static secret. When set it REPLACES the static-secret check for that platform; unset ⇒
# the static shared secret above stays in force (back-compat). Per-platform WEBHOOK_HMAC_SECRET_<PLATFORM>,
# else the shared CHANNEL_WEBHOOK_HMAC_SECRET.
# WEBHOOK_HMAC_SECRET_GRAB=
# CHANNEL_WEBHOOK_HMAC_SECRET=

# LINE OA / member CRM (all optional — unset = dev mock, no real LINE calls).
#   LINE_CHANNEL_TOKEN     — Messaging API channel access token (push to members' LINE userIds)
#   LINE_LOGIN_CHANNEL_ID  — LINE Login/LIFF channel id (verifies member id tokens → LINE userId)
LINE_CHANNEL_TOKEN=
LINE_LOGIN_CHANNEL_ID=

# Wallet passes (docs/29 V5) — member card in Apple/Google Wallet. All optional: unset = deterministic
# mock provider (pass payload + fake install link, nothing leaves the building). Real signing creds are an
# ops prerequisite — set them and the same code issues real passes (per-tenant override via settings too).
WALLET_APPLE_CERT_P12=          # base64 pass-type signing cert (.p12)
WALLET_APPLE_CERT_PASSWORD=
WALLET_APPLE_WWDR=              # Apple WWDR intermediate cert (PEM)
WALLET_APPLE_TEAM_ID=
WALLET_APPLE_PASS_TYPE_ID=      # e.g. pass.co.th.oshinei.member
WALLET_GOOGLE_SA_EMAIL=         # Google Wallet API service account
WALLET_GOOGLE_SA_KEY=           # service-account private key (PEM, \n-escaped)
WALLET_GOOGLE_ISSUER_ID=

# Anthropic (AI assistant + analytics). Empty = analytics fall back to rule-based.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# RAG (Phase D2): embedding provider (default 'local' deterministic, offline) + retrieval threshold
EMBED_PROVIDER=local
KB_MIN_SCORE=0.15

# CORS — explicit origins (comma-separated). NOT "*". REQUIRED in production (fail-closed): with
# credentials:true a missing value would fall back to http://localhost:3000, a fail-open default — the
# API now refuses to boot in prod when CORS_ORIGINS is unset (env.validation.ts).
CORS_ORIGINS=http://localhost:3000

# Number of trusted reverse proxies in front of the API (security review L-12). The audit-log client IP is
# derived from X-Forwarded-For, whose LEFT hops the client can forge. Default 0 = trust none → use the direct
# socket peer. Set to the count of your own proxies (e.g. 1 behind a single load balancer / Railway edge) so
# the real client IP is recovered from the rightmost trusted hop instead of a spoofable prefix.
TRUSTED_PROXY_HOPS=0

# Server
PORT=8000
NODE_ENV=development

# ── Web ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
# Content-Security-Policy rollout safety (security review M-1). The web app enforces a strict, per-request
# nonce CSP (script-src 'nonce-…' 'strict-dynamic') in production via src/middleware.ts. Set CSP_REPORT_ONLY=1
# to emit it as Content-Security-Policy-Report-Only (observe violations without blocking) for an initial
# deploy, then unset to enforce. Next still nonces its own scripts in report-only mode, so any report is a
# real inline-script violation, not framework noise.
CSP_REPORT_ONLY=
# LINE LIFF wrapper for /m (optional): the LIFF app id from LINE Developers Console. Set → opening /m
# inside LINE signs the member in with one tap (id_token → /api/member/auth/line; first time falls back
# to OTP and auto-links). Unset → the plain phone-OTP flow, no LIFF SDK loaded.
NEXT_PUBLIC_LIFF_ID=
# Public web-app base URL (API-side, optional): used to build customer-facing deep links — the printed
# QR resolver (`<base>/q?d=…`) and the PDPA consent-request message's link to the member app
# (`<base>/m`). Unset → QR images encode the raw payload and the consent message names the member app
# without a link. e.g. https://shop.example.com
WEB_BASE_URL=

# ── ETL (migration) ───────────────────────────────────────────
LEGACY_SQLITE_PATH=../Invisible ERP/Inventory_Master_DB.sqlite
LEGACY_MASTER_CSV=../Invisible ERP/Shared_Data/master_data.csv

# Multi-replica realtime fan-out (docs/24 R1-3): unset = in-memory SSE buses (single node / CI).
# Set to a Redis URL when running 2+ API replicas so live KDS/BI events reach every node.
# REALTIME_REDIS_URL=redis://localhost:6379

# Shared rate-limit store (security review L-8): unset = per-process counters for BOTH the edge per-IP limiter
# and the public-API per-key limiter (fine on a single node). Set to a Redis URL when running 2+ API replicas so
# the limits hold across nodes (else a client gets N× its budget). Falls back to REALTIME_REDIS_URL if that is
# set. Pair with TRUSTED_PROXY_HOPS (the number of trusted reverse proxies in front of the API) so the edge
# limiter keys on the real client IP behind a proxy rather than bucketing every client together.
# RATE_LIMIT_REDIS_URL=redis://localhost:6379

# Public web-to-lead form (CRM-2, POST /api/crm/web-to-lead): per-IP requests per window on its own strict
# edge bucket (default 20/min). The endpoint also carries a honeypot field dropped silently in the controller.
# RATE_LIMIT_WEB_LEAD_MAX=20

# Shared read cache (docs/27 §R1-6): unset = per-process in-memory TtlCache (single node / CI — behavior
# identical to before the adapter existed). Set to a Redis URL when running 2+ API replicas so the
# BI/finance read caches are shared across nodes and a tenant cache-bust reaches every node. A Redis
# failure degrades to local compute (throttled `cache_redis_degraded` ops alert), never a failed read.
# CACHE_REDIS_URL=redis://localhost:6379

# In-process scheduler tick (docs/27 R1-5 / AUD-ARC-07): unset/0 = OFF (default — the nightly GitHub cron
# in .github/workflows/bi-scheduler.yml triggers the due sweep). Set (ms, e.g. 300000 = 5 min) to make the
# API self-trigger the platform-wide sweep — duplicate triggers are safe (dueness re-checked at execution).
# SCHEDULER_TICK_MS=300000
# Heartbeat staleness threshold (hours, default 26): a scheduler heartbeat older than this raises the
# throttled `scheduler_heartbeat_stale` ops alert via the job worker's reap cycle.
# SCHEDULER_STALE_HOURS=26

# Required by db:seed when creating the initial admin (docs/27 R0-3): the seed never generates or logs
# a credential; the account is must_change_password until rotated on first login.
# SEED_ADMIN_PASSWORD=change-me-on-first-login

# ── G3 (docs/45, PDPA-05): hashed-audience export targets — ALL optional; nothing set = deterministic
# mock (the audience_export_sync job still runs, register rows say target=mock). Payloads are ALWAYS
# consent-filtered + sha256-hashed regardless of target.
# Generic webhook / CDP middleware (SSRF-gated: public https only):
# AUDIENCE_EXPORT_URL=
# AUDIENCE_EXPORT_TOKEN=
# Meta Custom Audiences (create the audience ONCE, pin its id — see common/audience-providers.ts):
# META_ADS_ACCESS_TOKEN=
# META_AUDIENCE_ID=
# META_GRAPH_VERSION=v21.0
# Google Customer Match (create the user list ONCE, pin its id):
# GOOGLE_ADS_DEVELOPER_TOKEN=
# GOOGLE_ADS_CLIENT_ID=
# GOOGLE_ADS_CLIENT_SECRET=
# GOOGLE_ADS_REFRESH_TOKEN=
# GOOGLE_ADS_CUSTOMER_ID=
# GOOGLE_ADS_USER_LIST_ID=
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=

{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "services/analytics-engine/Dockerfile"
  },
  "deploy": {
    "startCommand": "python run.py",
    "cronSchedule": "0 3 * * *",
    "restartPolicyType": "NEVER",
    "numReplicas": 1
  }
}

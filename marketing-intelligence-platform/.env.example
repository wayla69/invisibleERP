# ── Marketing Intelligence Platform — environment ──────────────────────────────────────────────────
# Copy to .env (local) or set as Railway service variables. NEVER commit real secrets.

# Data warehouse (Railway Postgres add-on injects DATABASE_URL automatically).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/midw
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Celery broker/backend (Railway Redis add-on injects REDIS_URL).
REDIS_URL=redis://localhost:6379/0

# ERP public API (the ONLY coupling to the ERP). Mint the key in the ERP:
#   POST /api/platform/api-keys  { "name": "marketing-intelligence", "scopes": ["analytics:read"] }
# The key is tenant-bound; the platform sees only that tenant's data.
ERP_API_URL=https://your-erp-host
ERP_API_KEY=ierp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Social listening API (optional). If SOCIAL_API_BASE_URL is unset the worker uses a built-in mock
# generator so the pipeline runs without external credentials.
SOCIAL_API_BASE_URL=
SOCIAL_API_KEY=
SOCIAL_PLATFORMS=tiktok,x,instagram,facebook
SOCIAL_MAX_RETRIES=4

# Scheduling / behaviour.
FETCH_INTERVAL_MIN=30       # social fetch cadence (minutes)
SYNC_WINDOW_DAYS=90         # how far back to pull ERP sales/customers each sync
MMM_OPTIMIZE=0             # 1 = scipy-optimize adstock theta per channel (slower, better fit)
TZ=Asia/Bangkok
LOG_LEVEL=INFO
